---
layout: compress
swcache: true
---

[
  {%- assign search_first = true -%}

  {%- for post in site.posts -%}
    {%- unless search_first -%},{%- endunless -%}
    {%- assign search_first = false -%}
    {%- capture description -%}
      {% include post-description.html %}
    {%- endcapture -%}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "categories": {{ post.categories | join: ', ' | jsonify }},
    "tags": {{ post.tags | join: ', ' | jsonify }},
    "date": "{{ post.date }}",
    "content": "{{ description }}"
  }
  {%- endfor -%}

  {%- comment %}Include tabs (collection: site.tabs){% endcomment -%}
  {%- for tab in site.tabs -%}
    {%- unless search_first -%},{%- endunless -%}
    {%- assign search_first = false -%}
    {%- capture tab_desc -%}
      {{ tab.content | markdownify | strip_html | strip_newlines | truncate: 200 }}
    {%- endcapture -%}
    {%- if tab.title -%}
      {%- assign tab_label = tab.title -%}
    {%- else -%}
      {%- assign tab_label = tab.url | remove_first: '/' | remove: '/index.html' | remove: '.html' | split: '/' | last | capitalize -%}
    {%- endif -%}
  {
    "title": {{ tab_label | jsonify }},
    "url": {{ tab.url | relative_url | jsonify }},
    "categories": "",
    "tags": "",
    "date": "",
    "content": {{ tab_desc | strip | jsonify }}
  }
  {%- endfor -%}

  {%- comment %}Include homepage{% endcomment -%}
  {%- for page in site.pages -%}
    {%- if page.path == 'index.md' or page.path == 'zh-CN/index.md' -%}
      {%- unless search_first -%},{%- endunless -%}
      {%- assign search_first = false -%}
      {%- capture page_desc -%}
        {{ page.content | markdownify | strip_html | strip_newlines | truncate: 200 }}
      {%- endcapture -%}
      {%- assign page_label = page.title | default: "About" -%}
  {
    "title": {{ page_label | jsonify }},
    "url": {{ page.url | relative_url | jsonify }},
    "categories": "",
    "tags": "",
    "date": "",
    "content": {{ page_desc | strip | jsonify }}
  }
    {%- endif -%}
  {%- endfor -%}
]
